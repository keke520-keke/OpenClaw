# OpenClaw 安全配置
# 复制此文件为 .env 并填入实际值

# ═══════════════════════════════════════════
# 密钥配置（必填）
# ═══════════════════════════════════════════
# 用于加密和CSRF令牌生成，请使用随机生成的长字符串
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
OPENCLAW_SECRET_KEY=your_secret_key_here

# ═══════════════════════════════════════════
# CORS配置
# ═══════════════════════════════════════════
# 允许的前端域名（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5178

# ═══════════════════════════════════════════
# 速率限制
# ═══════════════════════════════════════════
# 每分钟最大请求数
RATE_LIMIT_MAX_REQUESTS=100
# 突发请求上限
RATE_LIMIT_BURST=20

# ═══════════════════════════════════════════
# 企业微信推送（可选）
# ═══════════════════════════════════════════
# WX_HOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# ═══════════════════════════════════════════
# 服务器配置
# ═══════════════════════════════════════════
# HOST=0.0.0.0
# PORT=8000
